{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vineyard-visual-system.dev/schemas/screen.schema.json",
  "title": "Traceable product screen",
  "type": "object",
  "required": [
    "id",
    "name",
    "platform",
    "workflow_ids",
    "scenario_ids",
    "fixture_ids",
    "purpose",
    "primary_decision",
    "data_shown",
    "actions",
    "states",
    "component_ids",
    "route"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^SCR-[0-9]{3}$" },
    "name": { "type": "string", "minLength": 3 },
    "platform": {
      "enum": ["mobile", "desktop", "tablet", "responsive", "print"]
    },
    "workflow_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^WF-[0-9]{3}$" }
    },
    "scenario_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^SCN-[0-9]{3}-[0-9]{2}$" }
    },
    "fixture_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^FIX-[0-9]{3}$" }
    },
    "purpose": { "type": "string", "minLength": 15 },
    "primary_decision": { "type": "string", "minLength": 10 },
    "data_shown": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3 }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "kind"],
        "properties": {
          "id": { "type": "string", "pattern": "^ACT-[0-9]{3}$" },
          "label": { "type": "string", "minLength": 3 },
          "kind": {
            "enum": ["inspect", "advance", "resolve", "correct", "supersede"]
          },
          "transition": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string", "minLength": 2 },
              "to": { "type": "string", "minLength": 2 }
            },
            "additionalProperties": false
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "kind": { "not": { "const": "inspect" } } }
            },
            "then": {
              "required": ["transition"],
              "properties": { "transition": { "type": "object" } }
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "entry_points": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 }
    },
    "exit_points": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 }
    },
    "states": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "kind", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "kind": {
            "enum": [
              "normal",
              "urgent",
              "blocked",
              "partial",
              "corrected",
              "historical",
              "offline",
              "stale",
              "conflict",
              "completion"
            ]
          },
          "description": { "type": "string", "minLength": 8 }
        },
        "additionalProperties": false
      }
    },
    "permission_behavior": { "type": "string", "minLength": 8 },
    "offline_behavior": { "type": "string", "minLength": 8 },
    "validation_behavior": { "type": "string", "minLength": 8 },
    "component_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^CMP-[0-9]{3}$" }
    },
    "route": { "type": "string", "pattern": "^/" },
    "figma_frame_name": { "type": "string", "minLength": 3 }
  },
  "additionalProperties": false
}
