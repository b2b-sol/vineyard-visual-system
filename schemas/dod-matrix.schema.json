{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vineyard-visual-system.dev/schemas/dod-matrix.schema.json",
  "title": "Definition of Done gate matrix",
  "type": "object",
  "required": ["schema_version", "status", "criteria"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "status": {
      "enum": ["pending", "in_progress", "passed", "failed", "blocked"]
    },
    "criteria": {
      "type": "array",
      "minItems": 13,
      "maxItems": 13,
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "verification", "evidence"],
        "properties": {
          "id": { "type": "string", "pattern": "^G(?:[0-9]|1[0-2])$" },
          "title": { "type": "string", "minLength": 4 },
          "status": {
            "enum": ["pending", "in_progress", "passed", "failed", "blocked"]
          },
          "verification": { "type": "string", "minLength": 8 },
          "evidence": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 3 }
          }
        },
        "allOf": [
          {
            "if": { "properties": { "status": { "const": "passed" } } },
            "then": {
              "properties": { "evidence": { "type": "array", "minItems": 1 } }
            }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
