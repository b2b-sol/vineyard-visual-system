{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task.schema.json",
  "title": "Task",
  "type": "object",
  "required": [
    "id",
    "title",
    "phase",
    "status",
    "depends_on",
    "artifacts"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "phase": {
      "type": "string"
    },
    "status": {
      "enum": [
        "planned",
        "ready",
        "in_progress",
        "review",
        "revise",
        "validated",
        "merged",
        "complete",
        "blocked_external",
        "blocked_internal",
        "superseded",
        "cancelled"
      ]
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "gate_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "owner": {
      "type": "string"
    },
    "branch": {
      "type": ["string", "null"]
    },
    "pull_request": {
      "type": ["integer", "null"]
    },
    "commit": {
      "type": ["string", "null"]
    },
    "started_at": {
      "type": ["string", "null"]
    },
    "completed_at": {
      "type": ["string", "null"]
    },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
