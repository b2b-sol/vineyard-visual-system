{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vineyard-visual-system.dev/schemas/task.schema.json",
  "title": "Durable project task",
  "type": "object",
  "required": ["id", "title", "phase", "status", "depends_on", "artifacts", "acceptance_criteria", "checks", "gate_ids", "owner"],
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Z]+(?:-[A-Z]+)*-[0-9]{3}$" },
    "title": { "type": "string", "minLength": 5 },
    "phase": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "status": {
      "enum": ["planned", "ready", "in_progress", "review", "revise", "validated", "merged", "complete", "blocked_external", "blocked_internal", "superseded", "cancelled"]
    },
    "depends_on": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Z]+(?:-[A-Z]+)*-[0-9]{3}$" }
    },
    "artifacts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "acceptance_criteria": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "checks": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "gate_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^G(?:[0-9]|1[0-2])$" } },
    "owner": { "type": "string", "minLength": 2 },
    "branch": { "type": ["string", "null"] },
    "pull_request": { "type": ["integer", "null"], "minimum": 1 },
    "commit": { "type": ["string", "null"], "pattern": "^[0-9a-f]{7,40}$" },
    "started_at": { "type": ["string", "null"], "format": "date-time" },
    "completed_at": { "type": ["string", "null"], "format": "date-time" },
    "reviewers": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 2 } },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
