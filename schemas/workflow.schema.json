{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vineyard-visual-system.dev/schemas/workflow.schema.json",
  "title": "Evidence-backed vineyard workflow",
  "type": "object",
  "required": [
    "id",
    "name",
    "purpose",
    "classification",
    "confidence",
    "evidence_ids",
    "triggers",
    "roles",
    "inputs",
    "states",
    "steps",
    "decisions",
    "outputs",
    "records",
    "handoffs",
    "exceptions",
    "product_intervention",
    "source_anchors"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^WF-[0-9]{3}$" },
    "name": { "type": "string", "minLength": 3 },
    "purpose": { "type": "string", "minLength": 20 },
    "classification": {
      "enum": [
        "confirmed_source",
        "strong_inference",
        "product_decision",
        "requires_field_validation",
        "temporary_visual_assumption"
      ]
    },
    "confidence": {
      "enum": ["high", "medium-high", "medium", "medium-low", "low"]
    },
    "evidence_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^EVD-(00[1-9]|01[0-2])$"
      }
    },
    "seasonality": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 2 }
    },
    "frequency": { "type": "string", "minLength": 3 },
    "triggers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3 }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^ROLE-[A-Z0-9-]+$" }
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 2 }
    },
    "preconditions": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3 }
    },
    "states": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
    },
    "terminal_states": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
    },
    "transitions": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "id",
          "from",
          "to",
          "kind",
          "owner",
          "trigger",
          "description",
          "record_reads",
          "record_writes",
          "decision_ids",
          "exception_ids",
          "evidence_ids",
          "classification",
          "confidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^TRN-WF-[0-9]{3}-[0-9]{3}$"
          },
          "from": {
            "type": ["string", "null"],
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "to": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "kind": {
            "enum": [
              "observation",
              "recommendation",
              "approval",
              "assignment",
              "execution",
              "completion",
              "verification",
              "reconciliation",
              "correction",
              "supersession",
              "exception",
              "recovery",
              "cancellation",
              "communication"
            ]
          },
          "owner": { "type": "string", "pattern": "^ROLE-[A-Z0-9-]+$" },
          "trigger": { "type": "string", "minLength": 8 },
          "description": { "type": "string", "minLength": 10 },
          "record_reads": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^REC-[0-9]{3}$" }
          },
          "record_writes": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^REC-[0-9]{3}$" }
          },
          "decision_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^DEC-[0-9]{3}$" }
          },
          "exception_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^EXC-[0-9]{3}$" }
          },
          "evidence_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^EVD-(00[1-9]|01[0-2])$"
            }
          },
          "classification": {
            "enum": [
              "confirmed_source",
              "strong_inference",
              "product_decision",
              "requires_field_validation",
              "temporary_visual_assumption"
            ]
          },
          "confidence": {
            "enum": ["high", "medium-high", "medium", "medium-low", "low"]
          },
          "decision_outcome": {
            "type": "string",
            "minLength": 2
          }
        },
        "additionalProperties": false
      }
    },
    "steps": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "order",
          "stage",
          "description",
          "owner",
          "state_from",
          "state_to"
        ],
        "properties": {
          "order": { "type": "integer", "minimum": 1 },
          "stage": {
            "enum": [
              "observation",
              "recommendation",
              "approval",
              "assignment",
              "execution",
              "completion",
              "verification",
              "reconciliation",
              "correction",
              "supersession"
            ]
          },
          "description": { "type": "string", "minLength": 10 },
          "owner": { "type": "string", "pattern": "^ROLE-[A-Z0-9-]+$" },
          "state_from": { "type": ["string", "null"] },
          "state_to": { "type": "string", "minLength": 2 },
          "decision_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^DEC-[0-9]{3}$" }
          }
        },
        "additionalProperties": false
      }
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "question", "owner", "outcomes"],
        "properties": {
          "id": { "type": "string", "pattern": "^DEC-[0-9]{3}$" },
          "question": { "type": "string", "minLength": 10 },
          "owner": { "type": "string", "pattern": "^ROLE-[A-Z0-9-]+$" },
          "outcomes": {
            "type": "array",
            "minItems": 2,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 2 }
          }
        },
        "additionalProperties": false
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 2 }
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 2 }
    },
    "handoffs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3 }
    },
    "approvals": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3 }
    },
    "exceptions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3 }
    },
    "workarounds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3 }
    },
    "risks": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3 }
    },
    "product_intervention": {
      "enum": [
        "support",
        "automate",
        "record",
        "communicate",
        "analyze",
        "leave_external"
      ]
    },
    "source_anchors": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 8 }
    },
    "field_validation_questions": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 8 }
    }
  },
  "additionalProperties": false
}
