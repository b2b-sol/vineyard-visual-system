{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vineyard-visual-system.dev/schemas/task-registry.schema.json",
  "title": "Task registry",
  "type": "object",
  "required": ["schema_version", "tasks"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://vineyard-visual-system.dev/schemas/task.schema.json"
      }
    }
  },
  "additionalProperties": false
}
