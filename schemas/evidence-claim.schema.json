{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vineyard-visual-system.dev/schemas/evidence-claim.schema.json",
  "title": "Normalized workflow evidence claim",
  "type": "object",
  "required": [
    "id",
    "title",
    "claim",
    "classification",
    "confidence",
    "source_anchor",
    "source_citation_handles",
    "public_source_ids",
    "workflow_ids",
    "limitations",
    "field_validation_questions"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^EVD-[0-9]{3}$" },
    "title": { "type": "string", "minLength": 8 },
    "claim": { "type": "string", "minLength": 30 },
    "classification": {
      "enum": [
        "confirmed_source",
        "strong_inference",
        "product_decision",
        "field_validation_need"
      ]
    },
    "confidence": { "enum": ["high", "medium-high", "medium", "low"] },
    "source_anchor": {
      "type": "object",
      "required": ["path", "section_heading", "anchor_text"],
      "properties": {
        "path": { "const": "source/Vineyard-Workflow-Discovery-report.md" },
        "section_heading": { "type": "string", "minLength": 5 },
        "anchor_text": { "type": "string", "minLength": 8 }
      },
      "additionalProperties": false
    },
    "source_citation_handles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^turn[0-9]+(?:view|search)[0-9]+$"
      }
    },
    "public_source_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^BIB-[0-9]{3}$" }
    },
    "workflow_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^WF-[0-9]{3}$" }
    },
    "overlay_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^OVL-[0-9]{3}$" }
    },
    "limitations": { "type": "string", "minLength": 12 },
    "field_validation_questions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 12 }
    }
  },
  "additionalProperties": false
}
