{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vineyard-visual-system.dev/schemas/product-domain.schema.json",
  "title": "Bounded product domain",
  "type": "object",
  "required": [
    "id",
    "name",
    "purpose",
    "workflow_ids",
    "primary_entity_types",
    "accountable_role_ids",
    "screen_ids",
    "integration_seams"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^DOM-[0-9]{2}$" },
    "name": { "type": "string", "minLength": 3 },
    "purpose": { "type": "string", "minLength": 30 },
    "workflow_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^WF-[0-9]{3}$" }
    },
    "primary_entity_types": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3 }
    },
    "accountable_role_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^ROLE-[A-Z0-9-]+$" }
    },
    "screen_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^SCR-[0-9]{3}$" }
    },
    "integration_seams": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 8 }
    }
  },
  "additionalProperties": false
}
