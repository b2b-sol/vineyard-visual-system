{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vineyard-visual-system.dev/schemas/gate-results.schema.json",
  "title": "Quality gate evidence results",
  "type": "object",
  "required": ["schema_version", "evaluated_at", "gates"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "evaluated_at": { "type": "string", "format": "date-time" },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "status", "checks", "evidence", "commit_sha"],
        "properties": {
          "id": { "type": "string", "pattern": "^G(?:[0-9]|1[0-2])$" },
          "status": {
            "enum": ["pending", "in_progress", "passed", "failed", "blocked"]
          },
          "checks": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 3 }
          },
          "evidence": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 3 }
          },
          "commit_sha": {
            "type": ["string", "null"],
            "pattern": "^[0-9a-f]{40}$"
          }
        },
        "allOf": [
          {
            "if": { "properties": { "status": { "const": "passed" } } },
            "then": {
              "properties": {
                "evidence": { "type": "array", "minItems": 1 },
                "commit_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
              }
            }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
