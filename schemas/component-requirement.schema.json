{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vineyard-visual-system.dev/schemas/component-requirement.schema.json",
  "title": "Planned component contract",
  "type": "object",
  "required": [
    "id",
    "name",
    "category",
    "purpose",
    "screen_ids",
    "required_variants",
    "required_states",
    "accessibility_contract",
    "figma_key",
    "status"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^CMP-[0-9]{3}$" },
    "name": { "type": "string", "minLength": 3 },
    "category": {
      "enum": [
        "navigation",
        "identity",
        "workflow",
        "decision",
        "record",
        "status",
        "exception",
        "sync",
        "data_visualization",
        "input",
        "feedback"
      ]
    },
    "purpose": { "type": "string", "minLength": 20 },
    "screen_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^SCR-[0-9]{3}$" }
    },
    "required_variants": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3 }
    },
    "required_states": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3 }
    },
    "accessibility_contract": { "type": "string", "minLength": 20 },
    "figma_key": {
      "type": "string",
      "pattern": "^vineyard/[a-z0-9-]+(?:/[a-z0-9-]+)*$"
    },
    "status": { "enum": ["planned", "implemented", "deprecated"] }
  },
  "additionalProperties": false
}
