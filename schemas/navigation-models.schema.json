{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vineyard-visual-system.dev/schemas/navigation-models.schema.json",
  "title": "Responsive navigation models",
  "type": "object",
  "required": ["schema_version", "desktop", "mobile", "role_entries"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "desktop": { "$ref": "#/$defs/surface" },
    "mobile": { "$ref": "#/$defs/surface" },
    "role_entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role_id",
          "home_route",
          "workflow_ids",
          "primary_screen_ids",
          "exception_route"
        ],
        "properties": {
          "role_id": { "type": "string", "pattern": "^ROLE-[A-Z0-9-]+$" },
          "home_route": { "type": "string", "pattern": "^/" },
          "workflow_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^WF-[0-9]{3}$" }
          },
          "primary_screen_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^SCR-[0-9]{3}$" }
          },
          "exception_route": { "type": "string", "pattern": "^/" }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "surface": {
      "type": "object",
      "required": ["shell", "default_entry", "patterns"],
      "properties": {
        "shell": { "type": "string", "minLength": 20 },
        "default_entry": { "type": "string", "pattern": "^/" },
        "patterns": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 3 }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
