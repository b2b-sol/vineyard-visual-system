{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vineyard-visual-system.dev/schemas/manifest.schema.json",
  "title": "Generated master artifact manifest",
  "type": "object",
  "required": [
    "schema_version",
    "generated_from",
    "artifact_count",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "generated_from": { "const": "control/trace-nodes.json" },
    "artifact_count": { "type": "integer", "minimum": 1 },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "title", "path", "locator", "status"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "title": { "type": "string" },
          "path": { "type": "string" },
          "locator": { "type": "string" },
          "status": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
