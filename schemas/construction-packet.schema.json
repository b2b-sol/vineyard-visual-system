{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vineyard-visual-system.dev/schemas/construction-packet.schema.json",
  "title": "Implementation-ready workflow construction packet",
  "type": "object",
  "required": [
    "id",
    "title",
    "purpose",
    "workflow_ids",
    "scenario_ids",
    "fixture_ids",
    "screen_ids",
    "component_ids",
    "roles",
    "preconditions",
    "state_contract",
    "permission_contract",
    "data_contract",
    "interaction_contract",
    "copy_contract",
    "dependencies",
    "acceptance_criteria",
    "test_cases",
    "figma_mapping"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^PKT-[0-9]{3}$" },
    "title": { "type": "string", "minLength": 6 },
    "purpose": { "type": "string", "minLength": 20 },
    "workflow_ids": { "$ref": "#/$defs/workflowIds" },
    "scenario_ids": { "$ref": "#/$defs/scenarioIds" },
    "fixture_ids": { "$ref": "#/$defs/fixtureIds" },
    "screen_ids": { "$ref": "#/$defs/screenIds" },
    "component_ids": { "$ref": "#/$defs/componentIds" },
    "roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^ROLE-[A-Z0-9-]+$" }
    },
    "preconditions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 5 } },
    "state_contract": {
      "type": "object",
      "required": ["initial", "exception", "recovery", "terminal", "history_policy"],
      "properties": {
        "initial": { "type": "string", "minLength": 2 },
        "exception": { "type": "string", "minLength": 2 },
        "recovery": { "type": "string", "minLength": 2 },
        "terminal": { "type": "string", "minLength": 2 },
        "history_policy": { "type": "string", "minLength": 10 }
      },
      "additionalProperties": false
    },
    "permission_contract": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role_id", "may", "may_not"],
        "properties": {
          "role_id": { "type": "string", "pattern": "^ROLE-[A-Z0-9-]+$" },
          "may": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 3 } },
          "may_not": { "type": "array", "items": { "type": "string", "minLength": 3 } }
        },
        "additionalProperties": false
      }
    },
    "data_contract": {
      "type": "object",
      "required": ["required_entities", "stable_identifiers", "audit_fields"],
      "properties": {
        "required_entities": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 2 } },
        "stable_identifiers": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 2 } },
        "audit_fields": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 2 } }
      },
      "additionalProperties": false
    },
    "interaction_contract": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["action_id", "precondition", "result", "audit_event"],
        "properties": {
          "action_id": { "type": "string", "pattern": "^ACT-[0-9]{3}$" },
          "precondition": { "type": "string", "minLength": 5 },
          "result": { "type": "string", "minLength": 5 },
          "audit_event": { "type": "string", "minLength": 5 }
        },
        "additionalProperties": false
      }
    },
    "copy_contract": {
      "type": "object",
      "required": ["status_labels", "error_messages"],
      "properties": {
        "status_labels": { "type": "object", "minProperties": 2, "additionalProperties": { "type": "string", "minLength": 2 } },
        "error_messages": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 8 } }
      },
      "additionalProperties": false
    },
    "dependencies": { "type": "array", "items": { "type": "string", "minLength": 3 } },
    "acceptance_criteria": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 10 } },
    "test_cases": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "category", "assertion"],
        "properties": {
          "id": { "type": "string", "pattern": "^TEST-[0-9]{3}$" },
          "category": { "enum": ["normal", "exception", "recovery", "permission", "accessibility", "responsive", "data"] },
          "assertion": { "type": "string", "minLength": 10 }
        },
        "additionalProperties": false
      }
    },
    "figma_mapping": {
      "type": "object",
      "required": ["frame_name", "component_names", "stable_node_key"],
      "properties": {
        "frame_name": { "type": "string", "minLength": 3 },
        "component_names": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 3 } },
        "stable_node_key": { "type": "string", "pattern": "^figma-ready:" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "workflowIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^WF-[0-9]{3}$" } },
    "scenarioIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^SCN-[0-9]{3}-[0-9]{2}$" } },
    "fixtureIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^FIX-[0-9]{3}$" } },
    "screenIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^SCR-[0-9]{3}$" } },
    "componentIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^CMP-[0-9]{3}$" } }
  },
  "additionalProperties": false
}
