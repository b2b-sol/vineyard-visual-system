{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vineyard-visual-system.dev/schemas/transition-disposition.schema.json",
  "title": "Canonical transition product disposition",
  "type": "object",
  "required": [
    "transition_id",
    "workflow_id",
    "owner_role_id",
    "disposition",
    "screen_id",
    "action_id",
    "scenario_ids",
    "fixture_evidence_status",
    "rationale"
  ],
  "properties": {
    "transition_id": {
      "type": "string",
      "pattern": "^TRN-WF-[0-9]{3}-[0-9]{3}$"
    },
    "workflow_id": { "type": "string", "pattern": "^WF-[0-9]{3}$" },
    "owner_role_id": { "type": "string", "pattern": "^ROLE-[A-Z0-9-]+$" },
    "disposition": {
      "enum": ["user_action", "system_action", "external_action", "no_ui"]
    },
    "screen_id": { "type": ["string", "null"], "pattern": "^SCR-[0-9]{3}$" },
    "action_id": { "type": ["string", "null"], "pattern": "^ACT-[0-9]{3}$" },
    "scenario_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^SCN-[0-9]{3}-[0-9]{2}$" }
    },
    "fixture_evidence_status": {
      "enum": ["fixture_realized", "canonical_only"]
    },
    "rationale": { "type": "string", "minLength": 20 }
  },
  "additionalProperties": false
}
