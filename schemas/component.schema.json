{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vineyard-visual-system.dev/schemas/component.schema.json",
  "title": "Traceable design-system component",
  "type": "object",
  "required": [
    "id",
    "name",
    "purpose",
    "workflow_ids",
    "scenario_ids",
    "screen_ids",
    "required_data",
    "variants",
    "states",
    "accessibility",
    "semantic_contract",
    "code_path",
    "export_name",
    "figma_name"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^CMP-[0-9]{3}$" },
    "name": { "type": "string", "minLength": 3 },
    "purpose": { "type": "string", "minLength": 15 },
    "workflow_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^WF-[0-9]{3}$" }
    },
    "scenario_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^SCN-[0-9]{3}-[0-9]{2}$" }
    },
    "screen_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^SCR-[0-9]{3}$" }
    },
    "required_data": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 2 }
    },
    "optional_data": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 2 }
    },
    "variants": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 2 }
    },
    "states": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
    },
    "actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 }
    },
    "content_limits": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 }
    },
    "responsive_behavior": { "type": "string", "minLength": 8 },
    "accessibility": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 8 }
    },
    "error_behavior": { "type": "string", "minLength": 8 },
    "semantic_contract": {
      "type": "object",
      "required": ["ordered_stages", "non_color_cues", "history_is_immutable"],
      "properties": {
        "ordered_stages": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
        },
        "non_color_cues": { "type": "boolean", "const": true },
        "history_is_immutable": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    },
    "code_path": {
      "type": "string",
      "pattern": "^[^\\\\]+\\.(tsx|ts|jsx|js)$"
    },
    "export_name": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9]*$" },
    "figma_name": { "type": "string", "minLength": 3 },
    "token_dependencies": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3 }
    }
  },
  "additionalProperties": false
}
