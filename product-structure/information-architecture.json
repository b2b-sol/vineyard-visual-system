    "blocks/:blockId",
    "contracts/:contractId",
    "workflows/:workflowId/instances/:workflowInstanceId",
    "records/:recordInstanceId",
    "exceptions/:exceptionHistoryId",
    "people/:personId/assignments/:assignmentId"
  ],
