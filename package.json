{
  "name": "vineyard-visual-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A code-first vineyard operations visual system and workflow atlas.",
  "engines": {
    "node": ">=24.15.0 <25",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "format": "prettier --write \"{atlas,scripts,control,data,scenarios,schemas,screens,workflow-model,design-system,construction-packets,production-waves,figma,validation}/**/*.{ts,tsx,js,mjs,cjs,json,css,scss,md,yml,yaml}\" \"source/{README.md,bibliography.json,evidence.json}\" \"*.{html,json,js,mjs,ts}\" \".github/workflows/*.{yml,yaml}\"",
    "format:check": "prettier --check \"{atlas,scripts,control,data,scenarios,schemas,screens,workflow-model,design-system,construction-packets,production-waves,figma,validation}/**/*.{ts,tsx,js,mjs,cjs,json,css,scss,md,yml,yaml}\" \"source/{README.md,bibliography.json,evidence.json}\" \"*.{html,json,js,mjs,ts}\" \".github/workflows/*.{yml,yaml}\"",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "validate": "npm run validate:all",
    "validate:schema": "node scripts/validation/validate.mjs --scope schema",
    "validate:evidence": "node scripts/validation/validate.mjs --scope evidence",
    "validate:trace": "node scripts/validation/validate.mjs --scope trace",
    "validate:data": "node scripts/validation/validate.mjs --scope data",
    "generate:data": "node scripts/generate-data.ts",
    "validate:data-current": "node scripts/generate-data.ts --check",
    "generate:scenario-fixtures": "node scripts/generate-scenario-fixtures.mjs",
    "validate:scenario-fixtures-current": "node scripts/generate-scenario-fixtures.mjs --check",
    "generate:scenarios": "node scripts/generate-scenarios.ts",
    "validate:scenarios-current": "node scripts/generate-scenarios.ts --check",
    "generate:product": "npm run generate:scenario-fixtures && npm run generate:scenarios && node scripts/generate-product-model.ts && npm run generate:trace",
    "render:product-visuals": "node scripts/validate-product-mermaid.mjs",
    "validate:product": "node scripts/validation/product-model.mjs && npm run render:product-visuals",
    "validate:product-current": "npm run validate:scenario-fixtures-current && npm run validate:scenarios-current && node scripts/generate-product-model.ts --check",
    "validate:all": "node scripts/validation/validate.mjs --scope all && npm run validate:product",
    "generate:workflow-model": "node scripts/refine-workflow-ontology.mjs && npm run generate:workflow-visuals && npm run generate:trace",
    "validate:workflow-model-current": "node scripts/refine-workflow-ontology.mjs --check",
    "generate:workflow-visuals": "node scripts/generate-workflow-visuals.mjs",
    "validate:workflow-visuals": "node scripts/generate-workflow-visuals.mjs --check",
    "render:workflow-visuals": "node scripts/validate-mermaid.mjs",
    "generate:trace": "node scripts/generate-trace.mjs",
    "generate:wave-001-contracts": "node scripts/generate-wave-contracts.mjs",
    "validate:wave-001-contracts-current": "node scripts/generate-wave-contracts.mjs --check",
    "validate:wave-001": "node scripts/validation/wave-001.mjs",
    "validate:wave-001:complete": "node scripts/validation/wave-001.mjs --require-complete",
    "generate:tokens": "node scripts/generate-token-css.mjs",
    "validate:tokens": "node scripts/validation/design-tokens.mjs",
    "validate:tokens-current": "node scripts/generate-token-css.mjs --check",
    "validate:visual-directions": "node scripts/validation/visual-directions.mjs",
    "validate:trace-current": "node scripts/generate-trace.mjs --check",
    "validate:workflow": "node scripts/validation/validate.mjs --scope schema && npm run validate:workflow-model-current && npm run validate:workflow-visuals && npm run render:workflow-visuals",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:browser": "npm run build && playwright test",
    "test:visual-directions": "npm run build && playwright test atlas/tests/visual-directions.e2e.spec.ts",
    "test:browser:update": "playwright test --update-snapshots",
    "audit:repository": "node scripts/repository-audit.mjs",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run validate:all && npm run validate:workflow-model-current && npm run validate:workflow-visuals && npm run render:workflow-visuals && npm run validate:trace-current && npm run validate:data-current && npm run validate:product-current && npm run validate:tokens && npm run validate:tokens-current && npm run validate:visual-directions && npm run validate:wave-001-contracts-current && npm run validate:wave-001 && npm run test:unit && npm run build && npm run audit:repository"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@mermaid-js/mermaid-cli": "11.12.0",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
