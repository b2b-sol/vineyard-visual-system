{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Vineyard Visual System — Canopy Signal / sunlit fieldbook foundation",
  "$extensions": {
    "com.b2b-sol.vineyard": {
      "version": "1.0.0",
      "selectedDirection": "canopy-signal",
      "figmaCollection": "Vineyard Foundations",
      "decision": "DEC-013"
    }
  },
  "ref": {
