    "font": {
      "family": {
        "$type": "fontFamily",
        "display": {
          "$value": [
            "Iowan Old Style",
            "Palatino Linotype",
            "Book Antiqua",
            "Georgia",
            "serif"
          ]
        },
        "ui": {
          "$value": ["Aptos", "Segoe UI", "Helvetica Neue", "sans-serif"]
        },
        "mono": {
          "$value": [
            "SFMono-Regular",
            "Consolas",
            "Liberation Mono",
            "monospace"
          ]
        }
      },
      "size": {
        "$type": "dimension",
        "100": { "$value": { "value": 12, "unit": "px" } },
        "200": { "$value": { "value": 13, "unit": "px" } },
        "300": { "$value": { "value": 14, "unit": "px" } },
        "400": { "$value": { "value": 16, "unit": "px" } },
        "500": { "$value": { "value": 18, "unit": "px" } },
        "600": { "$value": { "value": 22, "unit": "px" } },
        "700": { "$value": { "value": 28, "unit": "px" } },
        "800": { "$value": { "value": 36, "unit": "px" } },
        "900": { "$value": { "value": 48, "unit": "px" } }
      },
      "weight": {
        "$type": "fontWeight",
        "regular": { "$value": 400 },
        "semibold": { "$value": 600 },
        "bold": { "$value": 700 }
      }
    },
    "space": {
      "$type": "dimension",
      "0": { "$value": { "value": 0, "unit": "px" } },
      "1": { "$value": { "value": 4, "unit": "px" } },
      "2": { "$value": { "value": 8, "unit": "px" } },
      "3": { "$value": { "value": 12, "unit": "px" } },
      "4": { "$value": { "value": 16, "unit": "px" } },
      "5": { "$value": { "value": 20, "unit": "px" } },
      "6": { "$value": { "value": 24, "unit": "px" } },
      "8": { "$value": { "value": 32, "unit": "px" } },
      "10": { "$value": { "value": 40, "unit": "px" } },
      "12": { "$value": { "value": 48, "unit": "px" } },
      "16": { "$value": { "value": 64, "unit": "px" } }
    },
    "radius": {
      "$type": "dimension",
      "sm": { "$value": { "value": 6, "unit": "px" } },
      "md": { "$value": { "value": 10, "unit": "px" } },
      "lg": { "$value": { "value": 14, "unit": "px" } },
      "xl": { "$value": { "value": 20, "unit": "px" } },
      "round": { "$value": { "value": 999, "unit": "px" } }
    },
    "motion": {
      "duration": {
        "$type": "duration",
        "quick": { "$value": { "value": 120, "unit": "ms" } },
        "standard": { "$value": { "value": 220, "unit": "ms" } }
      },
      "easing": {
        "$type": "cubicBezier",
        "productive": { "$value": [0.2, 0, 0, 1] }
      }
    },
    "shadow": {
      "$type": "shadow",
      "raised": {
        "$value": {
          "color": {
            "colorSpace": "srgb",
            "components": [0.078431, 0.12549, 0.098039],
            "alpha": 0.08,
            "hex": "#14201914"
          },
          "offsetX": { "value": 0, "unit": "px" },
          "offsetY": { "value": 8, "unit": "px" },
          "blur": { "value": 24, "unit": "px" },
          "spread": { "value": 0, "unit": "px" }
        }
      }
    }
  },
  "sys": {
    "$description": "Contextual meaning. Theme and accessibility modes replace this layer without changing component contracts.",
    "color": {
      "$type": "color",
      "canvas": { "$value": "{ref.color.mineral.50}" },
      "surface": {
        "base": { "$value": "{ref.color.mineral.0}" },
        "subtle": { "$value": "{ref.color.mineral.100}" },
        "raised": { "$value": "{ref.color.mineral.0}" },
        "inverse": { "$value": "{ref.color.vine.900}" }
      },
      "text": {
        "primary": { "$value": "{ref.color.ink.950}" },
        "secondary": { "$value": "{ref.color.ink.500}" },
        "muted": { "$value": "{ref.color.ink.300}" },
        "inverse": { "$value": "{ref.color.mineral.0}" },
        "link": { "$value": "{ref.color.water.700}" }
      },
      "border": {
        "subtle": { "$value": "{ref.color.mineral.200}" },
        "default": { "$value": "{ref.color.mineral.300}" },
        "strong": { "$value": "{ref.color.ink.500}" }
      },
      "action": {
        "primaryBackground": { "$value": "{ref.color.vine.700}" },
        "primaryText": { "$value": "{ref.color.mineral.0}" }
      },
      "map": {
        "selectedBoundary": { "$value": "{ref.color.water.700}" },
        "restrictedBoundary": { "$value": "{ref.color.clay.700}" },
        "staleBoundary": { "$value": "{ref.color.amber.700}" },
        "crossOrganizationBoundary": { "$value": "{ref.color.grape.700}" }
      },
      "focus": { "ring": { "$value": "{ref.color.water.700}" } },
      "feedback": {
        "positive": {
          "text": { "$value": "{ref.color.vine.700}" },
          "surface": { "$value": "{ref.color.vine.100}" }
        },
        "informative": {
          "text": { "$value": "{ref.color.water.700}" },
          "surface": { "$value": "{ref.color.water.100}" }
        },
        "notice": {
          "text": { "$value": "{ref.color.amber.700}" },
          "surface": { "$value": "{ref.color.amber.100}" }
        },
        "critical": {
          "text": { "$value": "{ref.color.clay.700}" },
          "surface": { "$value": "{ref.color.clay.100}" }
        },
        "revision": {
          "text": { "$value": "{ref.color.grape.700}" },
          "surface": { "$value": "{ref.color.grape.100}" }
        },
        "neutral": {
          "text": { "$value": "{ref.color.ink.650}" },
          "surface": { "$value": "{ref.color.mineral.100}" }
        }
      }
    },
    "density": {
      "compact": {
        "control": {
          "$type": "dimension",
          "$value": { "value": 40, "unit": "px" }
        }
      },
      "comfortable": {
        "control": {
          "$type": "dimension",
          "$value": { "value": 44, "unit": "px" }
        }
      },
      "field": {
        "control": {
          "$type": "dimension",
          "$value": { "value": 52, "unit": "px" }
        }
      }
    },
    "size": {
      "$type": "dimension",
      "sidebar": { "$value": { "value": 272, "unit": "px" } },
      "contentMax": { "$value": { "value": 1600, "unit": "px" } }
    }
  },
  "component": {
    "$description": "Aliases proven by the three lighthouse compositions.",
    "statusSignal": {
      "$extensions": {
        "com.b2b-sol.vineyard": {
          "componentId": "CMP-006",
          "figmaName": "Workflow state rail / Status signal",
          "figmaKey": "vineyard/status/workflow-state-rail"
        }
      },
      "blocked": {
        "background": {
          "$type": "color",
          "$value": "{sys.color.feedback.critical.surface}"
        },
        "text": {
          "$type": "color",
          "$value": "{sys.color.feedback.critical.text}"
        }
      },
      "stale": {
        "background": {
          "$type": "color",
          "$value": "{sys.color.feedback.notice.surface}"
        },
        "text": {
          "$type": "color",
          "$value": "{sys.color.feedback.notice.text}"
        }
      },
      "corrected": {
        "background": {
          "$type": "color",
          "$value": "{sys.color.feedback.revision.surface}"
        },
        "text": {
          "$type": "color",
          "$value": "{sys.color.feedback.revision.text}"
        }
      }
    },
    "button": {
      "$extensions": {
        "com.b2b-sol.vineyard": {
          "componentId": "CMP-007",
          "figmaName": "Transition action bar / Primary action",
          "figmaKey": "vineyard/workflow/transition-action-bar"
        }
      },
      "primary": {
        "background": {
          "$type": "color",
          "$value": "{sys.color.action.primaryBackground}"
        },
        "text": {
          "$type": "color",
          "$value": "{sys.color.action.primaryText}"
        }
      }
    },
    "map": {
      "$extensions": {
        "com.b2b-sol.vineyard": {
          "componentId": "CMP-026",
          "figmaName": "Map scope viewer / Boundary states",
          "figmaKey": "vineyard/data-visualization/map-scope-viewer"
        }
      },
      "selectedBlock": {
        "stroke": {
          "$type": "color",
          "$value": "{sys.color.map.selectedBoundary}"
        }
      },
      "restrictedBlock": {
        "stroke": {
          "$type": "color",
          "$value": "{sys.color.map.restrictedBoundary}"
        }
      },
      "staleBlock": {
        "stroke": {
          "$type": "color",
          "$value": "{sys.color.map.staleBoundary}"
        }
      },
      "crossOrganizationBlock": {
        "stroke": {
          "$type": "color",
          "$value": "{sys.color.map.crossOrganizationBoundary}"
        }
      }
    }
  }
}
