{
  "compilerOptions": {
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node", "vite/client", "vitest/globals"]
  },
  "include": [
    "atlas/src/**/*.ts",
    "atlas/src/**/*.tsx",
    "atlas/tests/**/*.ts",
    "atlas/tests/**/*.tsx",
    "scripts/**/*.ts",
    "*.config.ts"
  ],
  "exclude": [
    "atlas/dist",
    "coverage",
    "node_modules",
    "playwright-report",
    "review-exports/generated",
    "test-results"
  ]
}
